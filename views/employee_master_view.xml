<?xml version="1.0" encoding="utf-8" ?>

<odoo>
    <record id="view_employee_master_list" model="ir.ui.view">
        <field name="name">employee.master.list</field>
        <field name="model">employee.master</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="location"/>
                <field name="salary"/>
                <field name="net_salary"/>
            </list>
        </field>
    </record>

    <record id="view_employee_master_form" model="ir.ui.view">
        <field name="name">employee.master.form</field>
        <field name="model">employee.master</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="age"/>
                        <field name="date_of_birth"/>
                        <field name="location"/>
                        <field name="gender"/>
                        <field name="image" widget="image"/>
                        <field name="is_resident_mumbai"/>
                    </group>

                    <group>
                        <field name="salary"/>
                        <field name="employee_tax"/>
                        <field name="employee_pf"/>
                        <field name="net_salary"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_employee_master" model="ir.actions.act_window">
        <field name="name">Employee Master</field>
        <field name="res_model">employee.master</field>
        <field name="view_mode">list,form,kanban,graph</field>
    </record>


    <menuitem id="menu_employee_root" name="Employee"/>

    <menuitem id="menu_employee_master"
              name="Employee Master"
              parent="menu_employee_root"
              action="action_employee_master"/>

</odoo>